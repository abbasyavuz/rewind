# Rewind talks to any OpenAI-compatible Chat Completions endpoint, so you choose
# the provider and the model. Copy this file to `.env` (which is gitignored) and
# fill in the three values below.
#
#   REWIND_API_KEY   your key for the chosen provider (a dummy is fine for Ollama)
#   REWIND_BASE_URL  the provider's OpenAI-compatible base URL
#   REWIND_MODEL     the exact model id to run (no default — you pick it)
#
# Pick ONE provider — example base URLs:
#   OpenRouter   https://openrouter.ai/api/v1        (key from https://openrouter.ai/keys)
#   OpenAI       https://api.openai.com/v1           (key from https://platform.openai.com)
#   Together     https://api.together.xyz/v1
#   Groq         https://api.groq.com/openai/v1
#   Ollama       http://localhost:11434/v1           (local, self-hosted — any key works)
#   …or any other OpenAI-compatible gateway.

REWIND_API_KEY=
REWIND_BASE_URL=https://openrouter.ai/api/v1
REWIND_MODEL=

# --- examples/deterministic_oss.py only (the bitwise tier) ---------------------
# Needs a seedable, self-hosted model whose sampler you control (e.g. Ollama).
# No default model id — set your own.
REWIND_OSS_BASE_URL=http://localhost:11434/v1
REWIND_OSS_MODEL=
