# Rust
/target
**/target
# Cargo.lock IS committed: this workspace ships a binary (rewind-cli).

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Rewind artifacts + experiment outputs (don't commit captured runs / measurements)
*.rewind/
*.rewind
/runs/

# ...EXCEPT the two canned, PII-free headline-demo artifacts, so `rewind diff
# runs/support.rewind runs/support-fixed.rewind --verify` works on a fresh clone.
# (Re-include the dir, then the artifact subtrees; they hold only public keys.)
!/runs/
/runs/*
!/runs/support.rewind/
!/runs/support-fixed.rewind/

# Keys (NEVER commit signing keys)
*.ed25519
*.key
/keys/

# OS / editor
.DS_Store
.idea/
.vscode/

# Internal strategy / planning docs — keep local, NOT on GitHub
/docs/
/spec/
